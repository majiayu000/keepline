{
  "name": "claude-quota-menubar",
  "version": "1.0.0",
  "description": "Claude usage quota monitor for macOS menubar",
  "main": "dist/main.js",
  "scripts": {
    "dev": "npm run generate-icon && concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -w -p tsconfig.main.json",
    "dev:renderer": "vite",
    "build": "npm run generate-icon && npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "package": "electron-builder --mac",
    "typecheck": "tsc --noEmit",
    "generate-icon": "node scripts/generate-icon.js",
    "postinstall": "npm run generate-icon"
  },
  "dependencies": {
    "menubar": "^9.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  },
  "build": {
    "appId": "com.claude-hub.quota-menubar",
    "productName": "Claude Quota",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": ["dmg"]
    },
    "files": [
      "dist/**/*",
      "assets/iconTemplate.png",
      "assets/iconTemplate@2x.png",
      "!**/*.ts",
      "!**/*.map",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,README,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/.bin",
      "!**/*.d.ts"
    ],
    "asar": true,
    "compression": "maximum"
  }
}
