{
  "name": "claude-hub",
  "version": "1.0.0",
  "description": "The command center for Claude Code - Never lose your work again",
  "author": "Claude Hub Contributors",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-hub": "./dist/index.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "coding-assistant",
    "session-manager",
    "developer-tools",
    "terminal",
    "cli",
    "monitoring",
    "recovery"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anthropics/claude-hub.git"
  },
  "bugs": {
    "url": "https://github.com/anthropics/claude-hub/issues"
  },
  "homepage": "https://github.com/anthropics/claude-hub#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "public",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run build:client && bun run build:server",
    "build:client": "cd src/web/client && bun run build",
    "build:server": "bun build src/index.ts --outdir dist --target bun",
    "dev": "bun run src/index.ts",
    "dev:client": "cd src/web/client && bun run dev",
    "start": "bun dist/index.js",
    "web": "bun dist/index.js web",
    "typecheck": "tsc --noEmit && cd src/web/client && bun run typecheck",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@types/react": "^19.2.7",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "eventemitter3": "^5.0.1",
    "fastify": "^5.1.0",
    "hono": "^4.10.8",
    "ink": "^6.5.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/node": "^22.10.1",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.7.2"
  }
}
