{
  "name": "tasker",
  "version": "1.0.0",
  "description": "Claude Code session monitor and recovery tool",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tasker": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "dev": "bun run src/index.ts",
    "start": "bun dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/react": "^19.2.7",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "eventemitter3": "^5.0.1",
    "fastify": "^5.1.0",
    "hono": "^4.10.8",
    "ink": "^6.5.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "ink-spinner": "^5.0.0",
    "ink-table": "^3.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2"
  }
}
